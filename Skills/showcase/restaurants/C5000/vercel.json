{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/ai-pick.js": { "memory": 128, "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/ai-picker.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }
      ]
    },
    {
      "source": "/Samsung_TV.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "//note": "Secrets (GEMINI_API_KEY, GEMINI_MODEL, ALLOWED_ORIGINS) are NOT stored here on purpose — vercel.json is committed to git. Put them in .env.local instead (gitignored) or in the Vercel dashboard. See .env.example and DEPLOY.md."
}

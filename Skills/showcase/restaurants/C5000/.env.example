# =============================================================================
#  Samsung C5000 — environment variables
#  ---------------------------------------------------------------------------
#  HOW TO USE:
#    1. Copy this file to `.env.local` (which is gitignored).
#    2. Paste your real Gemini API key on the GEMINI_API_KEY line.
#    3. Save.
#    4. On deploy: `vercel --prod`  → Vercel CLI auto-uploads .env.local
#       as project env vars. (Or set them in the Vercel dashboard once.)
#
#  WHY NOT vercel.json?
#    `vercel.json` is committed to git. Anything in it is PUBLIC the moment
#    you push to GitHub. `.env.local` stays on your laptop + on Vercel only.
# =============================================================================

# ── Required: your free Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza__paste_your_real_key_here__

# ── Optional: pick the model. Defaults to gemini-2.5-flash-lite if unset.
#    Common choices (May 2026):
#      gemini-2.5-flash-lite   ← cheapest + fastest, great for this use case
#      gemini-2.5-flash        ← stronger reasoning, slightly slower/costlier
#      gemini-2.5-pro          ← overkill for channel-picking but supported
GEMINI_MODEL=gemini-2.5-flash-lite

# ── Optional: lock the proxy to specific domains (comma-separated).
#    By default, the proxy accepts requests from any of YOUR *.vercel.app
#    deployments + localhost. Set this only if you have a custom domain.
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
